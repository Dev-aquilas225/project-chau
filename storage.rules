rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isImageUnder(maxMb) {
      return request.resource.size < maxMb * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Images produit : lecture publique, upload réservé aux admins
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImageUnder(5);
    }

    // Avatars utilisateur : chacun gère le sien
    match /users/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid && isImageUnder(2);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
